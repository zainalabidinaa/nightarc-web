  </div>
  <div class="g4">
    <div class="plan"><div style="font-size:22px;margin-bottom:8px">✨</div><div style="font-size:15px;font-weight:700">Premium</div><div style="font-size:12px;color:var(--text2);margin:4px 0 12px">Pre-configured, ready instantly</div><div style="font-size:26px;font-weight:800">$4.99</div><div style="font-size:11px;color:var(--text3);margin-bottom:14px">/ month</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Up to 3 profiles</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Pre-configured content</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text3);margin-bottom:6px"><span style="color:var(--border2)">✗</span>Custom addons</div><button class="btn btn-g" style="width:100%;margin-top:12px">Select</button></div>
    <div class="plan cur"><div class="plan-top-bar"></div><div style="margin-bottom:8px"><span class="badge b-pur" style="font-size:9px">CURRENT PLAN</span></div><div style="font-size:22px;margin-bottom:8px">⚡</div><div style="font-size:15px;font-weight:700">Premium+</div><div style="font-size:12px;color:var(--text2);margin:4px 0 12px">Full control — manage your own sources</div><div style="font-size:26px;font-weight:800">$9.99</div><div style="font-size:11px;color:var(--text3);margin-bottom:14px">/ month</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Up to 5 profiles</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Manage own addons</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Priority support</div><button style="width:100%;margin-top:12px;background:var(--accent-light);color:var(--accent);border:1px solid rgba(109,40,217,.2);padding:6px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:default">Your current plan</button></div>
    <div class="plan"><div style="font-size:22px;margin-bottom:8px">👨‍👩‍👧</div><div style="font-size:15px;font-weight:700">Family</div><div style="font-size:12px;color:var(--text2);margin:4px 0 12px">Share with up to 7 invited users</div><div style="font-size:26px;font-weight:800">$14.99</div><div style="font-size:11px;color:var(--text3);margin-bottom:14px">/ month</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Unlimited profiles</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>7 invited users</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Members inherit addons</div><button class="btn btn-p" style="width:100%;margin-top:12px">Upgrade</button></div>
    <div class="plan" style="opacity:.65"><div style="font-size:22px;margin-bottom:8px">👑</div><div style="font-size:15px;font-weight:700">Admin</div><div style="font-size:12px;color:var(--text2);margin:4px 0 12px">Platform operators only</div><div style="font-size:17px;font-weight:800">By invite</div><div style="font-size:11px;color:var(--text3);margin-bottom:14px">only</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>All Family features</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Catalog CMS</div><div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);margin-bottom:6px"><span style="color:var(--accent);font-weight:700">✓</span>Analytics + user mgmt</div><button class="btn btn-g" style="width:100%;margin-top:12px;opacity:.5;cursor:default">Admin only</button></div>
  </div>
  <div class="g2">
    <div class="card card-pad">
      <div class="card-h"><span class="card-title">Billing details</span><span class="card-action">Update</span></div>
      <div class="bill-row"><span style="color:var(--text2)">Plan</span><span style="font-weight:600">Premium+</span></div>
      <div class="bill-row"><span style="color:var(--text2)">Status</span><span class="badge b-grn">Active</span></div>
      <div class="bill-row"><span style="color:var(--text2)">Next billing</span><span style="font-weight:600">Jul 9, 2026</span></div>
      <div class="bill-row"><span style="color:var(--text2)">Amount</span><span style="font-weight:600">$9.99 / month</span></div>
      <div class="bill-row"><span style="color:var(--text2)">Payment</span><span style="font-weight:600">Visa ••••4242</span></div>
      <div style="display:flex;gap:8px;margin-top:14px"><button class="btn btn-g btn-sm">Update card</button><button class="btn btn-d btn-sm">Cancel plan</button></div>
    </div>
    <div class="card card-pad">
      <div class="card-h"><span class="card-title">Invoice history</span><span class="card-action">Download all</span></div>
      <div class="row"><span style="font-size:11px;color:var(--text3);width:80px">Jun 9, 2026</span><span style="font-size:12px;flex:1">Premium+ monthly</span><span class="badge b-grn" style="font-size:9px;margin-right:8px">Paid</span><span style="font-size:13px;font-weight:600">$9.99</span></div>
      <div class="row"><span style="font-size:11px;color:var(--text3);width:80px">May 9, 2026</span><span style="font-size:12px;flex:1">Premium+ monthly</span><span class="badge b-grn" style="font-size:9px;margin-right:8px">Paid</span><span style="font-size:13px;font-weight:600">$9.99</span></div>
      <div class="row"><span style="font-size:11px;color:var(--text3);width:80px">Apr 9, 2026</span><span style="font-size:12px;flex:1">Premium+ monthly</span><span class="badge b-grn" style="font-size:9px;margin-right:8px">Paid</span><span style="font-size:13px;font-weight:600">$9.99</span></div>
    </div>
  </div>
</section>

<!-- ═══════════════════════
