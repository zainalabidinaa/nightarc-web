    <div class="tab" onclick="swTab(this)">Work</div>
  </div>
  <div class="g2">
    <div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px"><span style="font-size:14px;font-weight:600">Active addons</span><span style="font-size:11px;color:var(--text3)">9 installed</span></div>
      <div style="display:flex;flex-direction:column;gap:8px">
        <div class="addon"><div class="addon-logo" style="background:#fee2e2">🎬</div><div style="flex:1"><div style="font-size:13px;font-weight:600">Torrentio</div><div style="font-size:10px;color:var(--text3)">Streams · Catalogs · updated 2h ago</div></div><div class="toggle t-on"><div class="t-knob"></div></div></div>
        <div class="addon"><div class="addon-logo" style="background:var(--accent-light)">📺</div><div style="flex:1"><div style="font-size:13px;font-weight:600">TMDB Addon</div><div style="font-size:10px;color:var(--text3)">Catalogs · Meta · updated 1d ago</div></div><div class="toggle t-on"><div class="t-knob"></div></div></div>
        <div class="addon"><div class="addon-logo" style="background:var(--grn-bg)">🔤</div><div style="flex:1"><div style="font-size:13px;font-weight:600">OpenSubtitles</div><div style="font-size:10px;color:var(--text3)">Subtitles · updated 3d ago</div></div><div class="toggle t-on"><div class="t-knob"></div></div></div>
        <div class="addon"><div class="addon-logo" style="background:var(--amb-bg)">⭐</div><div style="flex:1"><div style="font-size:13px;font-weight:600">Cinemeta</div><div style="font-size:10px;color:var(--text3)">Meta · Catalogs</div></div><div class="toggle t-off"><div class="t-knob"></div></div></div>
        <div class="addon" style="border-style:dashed;justify-content:center;flex-direction:column;text-align:center;gap:4px;padding:16px;background:var(--surface2)"><div style="font-size:20px;color:var(--text3)">+</div><div style="font-size:12px;color:var(--text3)">Add addon</div></div>
      </div>
    </div>
    <div>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px"><span style="font-size:14px;font-weight:600">Inherited by friends &amp; family</span><span class="badge b-grn" style="font-size:9px">F&amp;F</span></div>
      <div style="background:var(--grn-bg);border:1px solid var(--grn-border);border-radius:10px;padding:11px 13px;margin-bottom:12px;font-size:12px;color:#065f46">Friends and family users automatically use your addons — they cannot add or remove their own.</div>
      <div style="display:flex;flex-direction:column;gap:8px">
        <div class="addon" style="opacity:0.5"><div class="addon-logo" style="background:#fee2e2">🎬</div><div style="flex:1"><div style="font-size:13px;font-weight:600">Torrentio</div><div style="font-size:10px;color:var(--text3)">Streams · Catalogs</div></div><span style="color:var(--text3);font-size:15px">🔒</span></div>
        <div class="addon" style="opacity:0.5"><div class="addon-logo" style="background:var(--accent-light)">📺</div><div style="flex:1"><div style="font-size:13px;font-weight:600">TMDB Addon</div><div style="font-size:10px;color:var(--text3)">Catalogs · Meta</div></div><span style="color:var(--text3);font-size:15px">🔒</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════
     SCREEN: CATALOGS
═══════════════════════ -->
<section class="screen" id="sc-catalogs">
  <div class="page-h" style="margin-bottom:20px">
    <div><div class="page-title">Catalogs</div><div class="page-sub">Drag to reorder · click to edit · toggle visibility</div></div>
    <div style="display:flex;gap:8px;align-items:center">
      <div style="display:flex;background:rgba(0,0,0,0.05);border-radius:8px;padding:2px">
        <button class="btn btn-sm" id="view-list" style="background:var(--surface);box-shadow:0 1px 3px rgba(0,0,0,.08);border:none" onclick="setCollView('list',this)">≡ List</button>
        <button class="btn btn-sm" id="view-grid" style="background:none;border:none;color:var(--text3)" onclick="setCollView('grid',this)">⊞ Grid</button>
      </div>
      <button class="btn btn-p" onclick="addCatalog()">+ New catalog</button>
    </div>
  </div>

  <!-- LIST VIEW -->
  <div id="coll-list-view">
    <div id="coll-list"></div>
  </div>

  <!-- GRID VIEW (hidden by default) -->
  <div id="coll-grid-view" style="display:none">
    <div id="coll-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px"></div>
  </div>
</section>

<!-- ═══════════════════════
     SCREEN: INVITES
═══════════════════════ -->
<section class="screen" id="sc-invites">
  <div class="page-h" style="margin-bottom:20px">
    <div><div class="page-title">Invite codes</div><div class="page-sub">Control who joins Luna and at what tier</div></div>
    <button class="btn btn-p">+ Generate code</button>
  </div>
  <div class="g2">
    <div class="card card-pad">
      <div class="card-h"><span class="card-title">Active codes</span></div>
      <div class="row" style="flex-wrap:wrap;gap:10px"><div><span class="inv-code">LUNA-X9KP</span><div style="font-size:11px;color:var(--text3);margin-top:6px"><span class="badge b-grn" style="font-size:9px">F&amp;F</span> · 2/7 used · expires Jun 30</div></div><div style="display:flex;gap:6px;margin-left:auto"><button class="btn btn-g btn-sm">Copy</button><button class="btn btn-d btn-sm">Revoke</button></div></div>
      <div class="row" style="flex-wrap:wrap;gap:10px"><div><span class="inv-code">LUNA-M4RZ</span><div style="font-size:11px;color:var(--text3);margin-top:6px"><span class="badge b-pnk" style="font-size:9px">PREMIUM</span> · 0/3 used · expires Jul 15</div></div><div style="display:flex;gap:6px;margin-left:auto"><button class="btn btn-g btn-sm">Copy</button><button class="btn btn-d btn-sm">Revoke</button></div></div>
      <div class="row" style="opacity:0.5;flex-wrap:wrap;gap:10px"><div><span class="inv-code" style="text-decoration:line-through;opacity:.6">LUNA-9QPW</span><div style="font-size:11px;color:var(--text3);margin-top:6px"><span class="badge b-amb" style="font-size:9px">PREMIUM+</span> · 1/1 used · expired</div></div><span class="badge b-gray" style="margin-left:auto">Expired</span></div>
    </div>
    <div class="card card-pad">
      <div class="card-h"><span class="card-title">Generate new code</span></div>
      <div style="margin-bottom:12px"><div class="label">Tier to grant</div><div class="tabs" style="margin-bottom:0"><div class="tab on" onclick="swTab(this)">F&amp;F</div><div class="tab" onclick="swTab(this)">Premium</div><div class="tab" onclick="swTab(this)">Premium+</div></div></div>
      <div style="margin-bottom:12px"><div class="label">Max uses</div><input class="input" value="5" style="width:100px"></div>
      <div style="margin-bottom:16px"><div class="label">Expiry (days)</div><input class="input" value="30" style="width:100px"></div>
      <button class="btn btn-p">Generate code</button>
    </div>
  </div>
</section>

</main>
</div>

<script>
const screens = ['purchase','overview','users','profiles','sub','addons','catalogs','invites'];

function goScreen(id) {
  screens.forEach(function(s) {
    var el = document.getElementById('sc-' + s);
    if (el) el.classList.toggle('active', s === id);
    var sb = document.getElementById('sb-' + s);
    if (sb) sb.classList.toggle('active', s === id);
  });
  var navMap = {purchase:'nav-purchase',overview:'nav-account',profiles:'nav-account',sub:'nav-account',invites:'nav-account',addons:'nav-account',catalogs:'nav-catalogs',users:'nav-admin'};
  document.querySelectorAll('.navbtn').forEach(function(b) { b.classList.remove('active'); });
  var navId = navMap[id];
  if (navId) { var btn = document.getElementById(navId); if (btn) btn.classList.add('active'); }
  window.scrollTo(0, 0);
}

function swTab(el) {
  el.closest('.tabs').querySelectorAll('.tab').forEach(function(t) { t.classList.remove('on'); });
  el.classList.add('on');
}

document.querySelectorAll('.toggle').forEach(function(t) {
  t.addEventListener('click', function() {
    this.classList.toggle('t-on');
    this.classList.toggle('t-off');
  });
});

var prices = {
  monthly: { premium: ['$4', '.99'], powerplus: ['$9', '.99'], family: ['$14', '.99'] },
  yearly:  { premium: ['$3', '.99'], powerplus: ['$7', '.99'], family: ['$11', '.99'] }
};

function setBilling(type, btn) {
  document.querySelectorAll('.tb-opt').forEach(function(b) { b.classList.remove('on'); });
  btn.classList.add('on');
  var p = prices[type];
  var perText = type === 'yearly' ? 'per month, billed yearly' : 'per month';
  Object.keys(p).forEach(function(k) {
    var d = document.getElementById('price-' + k + '-dollar');
    var c = document.getElementById('price-' + k + '-cents');
    var per = document.getElementById('per-' + k);
    if (d) d.textContent = p[k][0];
    if (c) c.textContent = p[k][1];
    if (per) per.textContent = perText;
  });
}
</script>
</body>
</html>
