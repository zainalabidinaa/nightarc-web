				"$(DERIVED_FILE_DIR)/GenerateMissingFrameworkInfoPlist.stamp",
			);
			runOnlyForDeploymentPostprocessing = 0;
			shellPath = /bin/sh;
			shellScript = "FRAMEWORKS_DIR=\"${BUILT_PRODUCTS_DIR}/${FRAMEWORKS_FOLDER_PATH}\"\nif [ ! -d \"${FRAMEWORKS_DIR}\" ]; then\n  touch \"${SCRIPT_OUTPUT_FILE_0}\"\n  exit 0\nfi\nfind \"${FRAMEWORKS_DIR}\" -name '*.framework' -maxdepth 1 -type d | while read -r FRAMEWORK; do\n  PLIST=\"${FRAMEWORK}/Info.plist\"\n  NAME=$(basename \"${FRAMEWORK}\" .framework)\n  BUNDLE_IDENTIFIER=\"com.kintan.ksplayer.$(printf \"%s\" \"${NAME}\" | tr '_' '-')\"\n  if [ ! -f \"${PLIST}\" ]; then\n    /usr/libexec/PlistBuddy \\\n      -c \"Add :CFBundleExecutable string ${NAME}\" \\\n      -c \"Add :CFBundleIdentifier string ${BUNDLE_IDENTIFIER}\" \\\n      -c \"Add :CFBundleInfoDictionaryVersion string 6.0\" \\\n      -c \"Add :CFBundleName string ${NAME}\" \\\n      -c \"Add :CFBundlePackageType string FMWK\" \\\n      -c \"Add :CFBundleShortVersionString string 1.0\" \\\n      -c \"Add :CFBundleVersion string 1\" \\\n      -c \"Add :MinimumOSVersion string 14.0\" \\\n      \"${PLIST}\"\n    echo \"note: Generated Info.plist for ${NAME}\"\n  else\n    /usr/libexec/PlistBuddy -c \"Set :CFBundleIdentifier ${BUNDLE_IDENTIFIER}\" \"${PLIST}\" 2>/dev/null || \\\n      /usr/libexec/PlistBuddy -c \"Add :CFBundleIdentifier string ${BUNDLE_IDENTIFIER}\" \"${PLIST}\"\n  fi\n  if [ \"${CODE_SIGNING_ALLOWED:-NO}\" = \"YES\" ] && [ -n \"${EXPANDED_CODE_SIGN_IDENTITY:-}\" ]; then\n    /usr/bin/codesign --force --sign \"${EXPANDED_CODE_SIGN_IDENTITY}\" \"${FRAMEWORK}\"\n  fi\ndone\ntouch \"${SCRIPT_OUTPUT_FILE_0}\"\n";
		};
/* End PBXShellScriptBuildPhase section */

